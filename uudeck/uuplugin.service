[Unit]
Description=NetEase UU Accelerator
Wants=network.target
After=network.target

[Service]
Type=simple
ProtectControlGroups=yes
ProtectKernelTunables=yes
ProtectKernelModules=yes
PrivateTmp=yes
NoNewPrivileges=yes
RestrictNamespaces=yes
RestrictRealtime=yes
ProtectSystem=strict
ProtectHome=yes
LockPersonality=yes
ReadWritePaths=/var/lib/uu
ExecStart=/bin/sh /usr/lib/uudeck/uuplugin_monitor.sh
Restart=on-failure
RestartSec=5

[Install]
WantedBy=multi-user.target
