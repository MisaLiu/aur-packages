pkgname=wineasio
pkgver=1.5.0
pkgrel=1

pkgdesc="ASIO driver implementation for Wine (giang17 fork)"
url="https://github.com/giang17/wineasio"
arch=('x86_64')
license=('LGPL-2.1-or-later' 'GPL-2.0-or-later')

options=('!lto' '!debug')
depends=('jack' 'python-pyqt5' 'realtime-privileges' 'wine>=11.0')
makedepends=('gcc')

install="$pkgname".install

source=(
  "https://github.com/giang17/wineasio/archive/refs/tags/v$pkgver.tar.gz"
)
sha256sums=(
  '140575976d932ed0a5fdbb17a90e71145b86ccae0a4ed03dae3a9e8136b1e23d'
)

build() {
  cd "$pkgname-$pkgver"
  make WINE_PREFIX=/usr -f Makefile.wine11 all
}

package() {
  cd "$pkgname-$pkgver"

  install -D -m755 build_wine11/"$pkgname"64.so "$pkgdir"/usr/lib/wine/x86_64-unix/"$pkgname"64.so
  install -D -m644 build_wine11/"$pkgname"64.dll "$pkgdir"/usr/lib/wine/x86_64-windows/"$pkgname"64.dll

  install -D -m755 build_wine11/"$pkgname".so "$pkgdir"/usr/lib/wine/x86_64-unix/"$pkgname".so
  install -D -m644 build_wine11/"$pkgname".dll "$pkgdir"/usr/lib/wine/i386-windows/"$pkgname".dll

  install -D -m755 gui/wineasio-settings "$pkgdir"/usr/bin/wineasio-settings
  install -D -m644 gui/settings.py "$pkgdir"/usr/share/"$pkgname"/settings.py
  install -D -m644 gui/ui_settings.py "$pkgdir"/usr/share/"$pkgname"/ui_settings.py
  install -D -m644 README.md "$pkgdir"/usr/share/"$pkgname"/README.md
  install -D -m755 wineasio-register "$pkgdir"/usr/bin/wineasio-register
}
# vim:set ts=2 sw=2 et:
